        "body": {
          "error": "document_not_found",
          "code": "document_not_found"
        }
      },
      "passed": true
    },
    {
      "name": "edge:foreign->404 document_not_found",
      "expected": {
        "status": 404,
        "code": "document_not_found"
      },
      "actual": {
        "status": 404,
        "body": {
          "error": "document_not_found",
          "code": "document_not_found"
        }
      },
      "passed": true
    },
    {
      "name": "edge:random->404 document_not_found",
      "expected": {
        "status": 404,
        "code": "document_not_found"
      },
      "actual": {
        "status": 404,
        "body": {
          "error": "document_not_found",
          "code": "document_not_found"
        }
      },
      "passed": true
    },
    {
      "name": "edge:visible->200 signed url",
      "expected": 200,
      "actual": 404,
      "passed": false
    },
    {
      "name": "edge:uniform response for hidden/foreign/random",
      "expected": true,
      "actual": true,
      "passed": true
    }
