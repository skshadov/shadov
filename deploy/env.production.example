# Скопировать в /var/www/shadov/.env.production на VPS.
# Файл НИКОГДА не коммитится в git (.gitignore покрывает .env*).
#
# Значения брать из Lovable Cloud → Backend → Settings → Project API keys.
# Это те же ключи, что использует Lovable preview/published — менять не нужно.

NODE_ENV=production
PORT=3000
HOST=127.0.0.1

# Supabase (server-side runtime — НЕ префикс VITE_)
SUPABASE_URL=https://shbgsrryredmememwgtn.supabase.co
SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InNoYmdzcnJ5cmVkbWVtZW13Z3RuIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODIwODg2MDEsImV4cCI6MjA5NzY2NDYwMX0.PhSGsvLtOttY0Qe0rg8MwIk0R4Blvale3LXY7N9te4E
SUPABASE_SERVICE_ROLE_KEY=__PASTE_FROM_LOVABLE_CLOUD__

# Дублируем для клиентского бандла (Vite читает VITE_* в build-time, но Nitro Node
# тоже использует их при SSR-старте, если что-то прочитается из import.meta.env).
VITE_SUPABASE_URL=https://shbgsrryredmememwgtn.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InNoYmdzcnJ5cmVkbWVtZW13Z3RuIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODIwODg2MDEsImV4cCI6MjA5NzY2NDYwMX0.PhSGsvLtOttY0Qe0rg8MwIk0R4Blvale3LXY7N9te4E

